   "id": "350ef36c720f9476",
   "metadata": {},
   "outputs": [],
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Tester: Анализ физических констант и LHC частиц\\n\\n\",\n",
    "    \"Этот Jupyter ноутбук переключает ./Tester на интерактивный режим.\\n\\n\",\n",
    "    \"- Парсит CODATA константы из Markdown в CSV\\n\",\n",
    "    \"- Парсит LHCb частицы из Markdown в CSV\\n\",\n",
    "    \"- Загружает реестр формул из YAML\\n\",\n",
    "    \"- Вычисляет константы (lookup, sympy, linear fit)\\n\",\n",
    "    \"- Генерирует отчёты и графики\\n\\n\",\n",
    "    \"**Запускайте ячейки последовательно!**\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import re\\\\n\",\n",
    "    \"import os\\\\n\",\n",
    "    \"import yaml\\\\n\",\n",
    "    \"import pandas as pd\\\\n\",\n",
    "    \"import numpy as np\\\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\\\n\",\n",
    "    \"import sympy as sp\\\\n\",\n",
    "    \"from scipy.stats import linregress\\\\n\\\\n\",\n",
    "    \"%matplotlib inline\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. Парсер CODATA констант\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"def parse_value(s):\\\\n\",\n",
    "    \"    \\u0022\\u0022\\u0022Parse messy value like '7294.299 541 71' or '6.644 657 3450 e-27'\\u0022\\u0022\\u0022\\\\n\",\n",
    "    \"    s = re.sub(r'\\\\s+', '', s)  # Remove spaces\\\\n\",\n",
    "    \"    s = re.sub(r'e(\\\\+?)(\\\\d+)', r' scientific E\\\\g\\\\u003c1\\\\u003e\\\\g\\\\u003c2\\\\u003e', s)  # Prep\\\\n\",\n",
    "    \"    try:\\\\n\",\n",
    "    \"        return float(s.replace('e-', 'E-').replace('e+', 'E+'))\\\\n\",\n",
    "    \"    except ValueError:\\\\n\",\n",
    "    \"        return np.nan\\\\n\\\\n\",\n",
    "    \"with open('Universe/Физические_константы.md', 'r', encoding='utf-8') as f:\\\\n\",\n",
    "    \"    lines = f.read().splitlines()\\\\n\\\\n\",\n",
    "    \"data = []\\\\n\",\n",
    "    \"in_table = False\\\\n\",\n",
    "    \"for i, line in enumerate(lines):\\\\n\",\n",
    "    \"    line = line.strip()\\\\n\",\n",
    "    \"    if 'Quantity | Value | Uncertainty | Unit' in line:\\\\n\",\n",
    "    \"        in_table = True\\\\n\",\n",
    "    \"        continue\\\\n\",\n",
    "    \"    if in_table and line.startswith('|') and '---' not in line:\\\\n\",\n",
    "    \"        parts = [p.strip() for p in line.split('|')][1:-1]\\\\n\",\n",
    "    \"        if len(parts) == 4:\\\\n\",\n",
    "    \"            qty, val_str, unc_str, unit = parts\\\\n\",\n",
    "    \"            val = parse_value(val_str)\\\\n\",\n",
    "    \"            unc = parse_value(unc_str) if unc_str != '(exact)' else 0.0\\\\n\",\n",
    "    \"            data.append({'Quantity': qty, 'Value': val, 'Uncertainty': unc, 'Unit': unit})\\\\n\\\\n\",\n",
    "    \"df = pd.DataFrame(data)\\\\n\",\n",
    "    \"df.to_csv('codata_2022.csv', index=False)\\\\n\",\n",
    "    \"print('CODATA CSV created. Shape:', df.shape)\\\\n\",\n",
    "    \"print(df[df['Quantity'].str.contains('proton|mass|MeV', case=False, na=False)][['Quantity', 'Value', 'Uncertainty']])\\\\n\",\n",
    "    \"df.head()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. Парсер LHC частиц\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"def parse_mass(mass_str):\\\\n\",\n",
    "    \"    \\u0022\\u0022\\u0022Parse '10530 ± 10', '4449.8 ± 3.0', '4694^{+16}_{-5}' → central, unc_low, unc_high\\u0022\\u0022\\u0022\\\\n\",\n",
    "    \"    central_match = re.search(r'(\\\\d+(?:\\\\.\\\\d+)?)', mass_str)\\\\n\",\n",
    "    \"    if not central_match:\\\\n\",\n",
    "    \"        return np.nan, np.nan, np.nan\\\\n\",\n",
    "    \"    central = float(central_match.group(1))\\\\n\",\n",
    "    \"    \\\\n\",\n",
    "    \"    sym_match = re.search(r'±\\\\s*(\\\\d+(?:\\\\.\\\\d+)?)', mass_str)\\\\n\",\n",
    "    \"    if sym_match:\\\\n\",\n",
    "    \"        unc = float(sym_match.group(1))\\\\n\",\n",
    "    \"        return central, unc, unc\\\\n\",\n",
    "    \"    \\\\n\",\n",
    "    \"    up_match = re.search(r'\\\\+\\\\s*(\\\\d+(?:\\\\.\\\\d+)?)', mass_str)\\\\n\",\n",
    "    \"    down_match = re.search(r'-\\\\s*(\\\\d+(?:\\\\.\\\\d+)?)', mass_str)\\\\n\",\n",
    "    \"    unc_low = float(down_match.group(1)) if down_match else 0\\\\n\",\n",
    "    \"    unc_high = float(up_match.group(1)) if up_match else 0\\\\n\",\n",
    "    \"    return central, unc_low, unc_high\\\\n\\\\n\",\n",
    "    \"with open('Physics/Вибрации/Вселенная_и_вибрации.md', 'r', encoding='utf-8') as f:\\\\n\",\n",
    "    \"    lines = f.read().splitlines()\\\\n\\\\n\",\n",
    "    \"data = []\\\\n\",\n",
    "    \"in_table = False\\\\n\",\n",
    "    \"for line in lines:\\\\n\",\n",
    "    \"    line = line.strip()\\\\n\",\n",
    "    \"    if line.startswith('| № | Вибрация | Масса'):\\\\n\",\n",
    "    \"        in_table = True\\\\n\",\n",
    "    \"        continue\\\\n\",\n",
    "    \"    if in_table and line.startswith('|') and not line.startswith('|---'):\\\\n\",\n",
    "    \"        parts = [p.strip() for p in line.split('|')][1:-1]\\\\n\",\n",
    "    \"        if len(parts) >= 4:\\\\n\",\n",
    "    \"            num = parts[0]\\\\n\",\n",
    "    \"            name = parts[1]\\\\n\",\n",
    "    \"            mass_str = parts[2]\\\\n\",\n",
    "    \"            q_str = parts[3]\\\\n\",\n",
    "    \"            central, unc_low, unc_high = parse_mass(mass_str)\\\\n\",\n",
    "    \"            q = int(q_str) if q_str.isdigit() else np.nan\\\\n\",\n",
    "    \"            data.append({'id': num, 'name': name, 'mass': central, 'unc_low': unc_low, 'unc_high': unc_high, 'Q': q})\\\\n\\\\n\",\n",
    "    \"df = pd.DataFrame(data)\\\\n\",\n",
    "    \"df.to_csv('lhc_particles.csv', index=False)\\\\n\",\n",
    "    \"print('LHC CSV created. Shape:', df.shape)\\\\n\",\n",
    "    \"print(df.head())\\\\n\",\n",
    "    \"df\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. Реестр формул\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"with open('Tester/formulas_registry.yaml', 'r', encoding='utf-8') as f:\\\\n\",\n",
    "    \"    registry = yaml.safe_load(f)['formulas']\\\\n\",\n",
    "    \"print(registry)\\\\n\",\n",
    "    \"yaml.dump(registry, default_flow_style=False)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Вычисление всех констант\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Load data\\\\n\",\n",
    "    \"codata_df = pd.read_csv('codata_2022.csv')\\\\n\",\n",
    "    \"lhc_df = pd.read_csv('lhc_particles.csv').dropna(subset=['Q'])\\\\n\",\n",
    "    \"lhc_df['ln_m'] = np.log(lhc_df['mass'])\\\\n\\\\n\",\n",
    "    \"# mp_proton\\\\n\",\n",
    "    \"mp_proton = codata_df[codata_df['Quantity'].str.contains('proton mass energy equivalent in MeV', case=False, na=False)]['Value'].iloc[0]\\\\n\",\n",
    "    \"print(f&quot;mp_proton: {mp_proton:.3f} MeV&quot;)\\\\n\\\\n\",\n",
    "    \"results = []\\\\n\",\n",
    "    \"for fmla in registry:\\\\n\",\n",
    "    \"    fid = fmla['id']\\\\n\",\n",
    "    \"    ftype = fmla['type']\\\\n\",\n",
    "    \"    if ftype == 'codata_lookup':\\\\n\",\n",
    "    \"        mask = codata_df['Quantity'].str.contains(fmla['codata_query'], case=False, na=False)\\\\n\",\n",
    "    \"        val = codata_df.loc[mask, 'Value'].iloc[0] if mask.any() else np.nan\\\\n\",\n",
    "    \"        expected = fmla.get('expected', np.nan)\\\\n\",\n",
    "    \"        diff = abs(val - expected) / expected * 100 if expected and not np.isnan(expected) else 0\\\\n\",\n",
    "    \"    elif ftype == 'sympy':\\\\n\",\n",
    "    \"        expr_str = fmla['formula']\\\\n\",\n",
    "    \"        expr = sp.sympify(expr_str)\\\\n\",\n",
    "    \"        subs = {k: v for k, v in fmla['inputs'].items()}\\\\n\",\n",
    "    \"        if 'm' in subs:\\\\n\",\n",
    "    \"            subs['m'] = fmla['params']['m']\\\\n\",\n",
    "    \"        subs['mp'] = mp_proton\\\\n\",\n",
    "    \"        subs = {k: float(v) if isinstance(v, (int, float)) else v for k, v in subs.items()}\\\\n\",\n",
    "    \"        val = float(expr.subs(subs))\\\\n\",\n",
    "    \"        expected_str = fmla.get('expected', '0')\\\\n\",\n",
    "    \"        expected_num = float(re.sub(r'[~]', '', expected_str))\\\\n\",\n",
    "    \"        diff = abs(val - expected_num) / expected_num * 100\\\\n\",\n",
    "    \"    elif ftype == 'linear_fit':\\\\n\",\n",
    "    \"        slope, intercept, r, p, se = linregress(lhc_df['Q'], lhc_df['ln_m'])\\\\n\",\n",
    "    \"        val = slope\\\\n\",\n",
    "    \"        expected = fmla.get('expected', np.nan)\\\\n\",\n",
    "    \"        diff = abs(val - expected) / expected * 100 if expected else 0\\\\n\",\n",
    "    \"    else:\\\\n\",\n",
    "    \"        val = np.nan\\\\n\",\n",
    "    \"        diff = np.nan\\\\n\",\n",
    "    \"    results.append({\\\\n\",\n",
    "    \"        'id': fid,\\\\n\",\n",
    "    \"        'name': fmla['name'],\\\\n\",\n",
    "    \"        'computed': round(val, 4),\\\\n\",\n",
    "    \"        'expected': fmla.get('expected'),\\\\n\",\n",
    "    \"        'diff_%': round(diff, 2) if not np.isnan(diff) else np.nan\\\\n\",\n",
    "    \"    })\\\\n\\\\n\",\n",
    "    \"res_df = pd.DataFrame(results)\\\\n\",\n",
    "    \"display(res_df)\\\\n\\\\n\",\n",
    "    \"# Reports\\\\n\",\n",
    "    \"os.makedirs('reports', exist_ok=True)\\\\n\",\n",
    "    \"res_df.to_markdown('reports/all_constants.md', index=False)\\\\n\",\n",
    "    \"res_df.to_csv('reports/all_constants.csv', index=False)\\\\n\\\\n\",\n",
    "    \"# Plot\\\\n\",\n",
    "    \"expected_vals = [float(re.sub(r'[~]', '', e)) if isinstance(e, str) else e for e in res_df['expected']]\\\\n\",\n",
    "    \"plt.figure(figsize=(8, 6))\\\\n\",\n",
    "    \"plt.scatter(expected_vals, res_df['computed'], alpha=0.7)\\\\n\",\n",
    "    \"plt.plot([0, max(max(expected_vals), max(res_df['computed'].dropna()))], \\\\n\",\n",
    "    \"         [0, max(max(expected_vals), max(res_df['computed'].dropna()))], 'r--', label='Ideal')\\\\n\",\n",
    "    \"plt.xlabel('Expected')\\\\n\",\n",
    "    \"plt.ylabel('Computed')\\\\n\",\n",
    "    \"plt.title('Constants Verification')\\\\n\",\n",
    "    \"plt.legend()\\\\n\",\n",
    "    \"plt.savefig('reports/constants_scatter.png', dpi=150)\\\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
