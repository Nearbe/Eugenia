# Eugenia Environment Configuration
# Copy this file to .env and fill in your local LLM API settings

# Local LLM API endpoint (e.g., Ollama, LM Studio, etc.)
LLM_API_URL=http://localhost:11434/api/generate

# Model name to use (e.g., llama2, gemma, mistral)
LLM_MODEL=llama2

# API key if required (leave empty for local models)
LLM_API_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Cache directory for intermediate results
CACHE_DIR=./cache

# Output directory for generated files
OUTPUT_DIR=./output
