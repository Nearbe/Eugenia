# Configuration for running Junie with a local LLM via terminal
# Copy this file to .env and adjust values as needed.

# --- OpenAI-Compatible API Settings (Most common for agents) ---
# The base URL for your local LLM server (e.g., Ollama, LM Studio, etc.)
# User's LM Studio API: http://192.168.1.91:1234/v1
OPENAI_API_BASE=http://192.168.1.91:1234/v1
OPENAI_BASE_URL=http://192.168.1.91:1234/v1

# Your API Key
OPENAI_API_KEY=sk-lm-fp4sIXzQ:Ero2vvZ3skty30Ul8rnT

# --- Junie-Specific Settings (if applicable) ---
# Note: Junie CLI uses model IDs defined in ~/.junie/models/ or .junie/models/
# We created .junie/models/qwen-local.json for this project.
JUNIE_API_BASE=http://192.168.1.91:1234/v1
JUNIE_API_KEY=sk-lm-fp4sIXzQ:Ero2vvZ3skty30Ul8rnT
JUNIE_MODEL=qwen3-32b-merge-math4-science4-submath05-med05-other1-mlx

# Available Models for LM Studio:
# - gemma-4-e4b-it-mlx
# - gemma-4-26b-a4b-it-mlx
# - google/gemma-4-26b-a4b
# - google/gemma-4-e2b
# - gpt-oss-120b-mlx-crack
# - harmonic-hermes-9b-mlx
